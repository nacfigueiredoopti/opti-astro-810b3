---
import type { DisplaySettingsFragment, OptiFormsPrebuiltListElement } from '../../../../__generated/sdk';
import type { ContentPayload } from '../../../graphql/shared/ContentPayload';
import { PREBUILT_LISTS, LIST_META } from './prebuiltLists';

export interface Props {
    data: OptiFormsPrebuiltListElement;
    contentPayload: ContentPayload;
    displaySettings: DisplaySettingsFragment[];
    nodeKey?: string;
}

const { data, nodeKey } = Astro.props as Props;
const { PrebuiltListType, Label, Placeholder, Tooltip } = data;

const listKey = PrebuiltListType ?? '';
const options = PREBUILT_LISTS[listKey] ?? [];
const meta = LIST_META[listKey];

const placeholderText = Placeholder || meta?.placeholder || 'Select an option...';
const inputId = Label?.replace(/\s+/g, '_') || `prebuilt-list-${Math.random().toString(36).substr(2, 4)}`;
---

<div class="form-control w-full" data-field-name={Label} data-field-key={nodeKey || undefined}>
    {Label && (
        <label
            class="label"
            for={inputId}
        >
            <span class="label-text text-base font-medium text-base-content/80">{Label}</span>
        </label>
    )}

    <select
        class:list={[
            "select select-bordered w-full rounded-xl bg-base-100 border-base-300 shadow-sm",
            "transition-all duration-200 ease-in-out",
            "hover:border-primary/50 hover:shadow-md",
            "focus:border-primary focus:ring-2 focus:ring-primary/20 focus:shadow-md focus:outline-none",
        ]}
        id={inputId}
        name={inputId}
        autocomplete={meta?.autocomplete || undefined}
        title={Tooltip || undefined}
    >
        <option value="" disabled selected class="text-base-content/40">
            {placeholderText}
        </option>
        {options.map((opt) => (
            <option value={opt.value}>{opt.label}</option>
        ))}
    </select>
</div>
