---
import type { Locales } from 'astro';
import { getOptimizelySdk } from '../../../../graphql/getSdk';
import type { ContentPayload } from '../../../../graphql/shared/ContentPayload';
import { isEditContext } from '../../../shared/utils.ts';

import FormComponents from '../../_FormComponents.astro';
import { getRowStyles } from '../../../compositions/Row/RowHelper';
import { getGlobalStyles } from '../../../shared/globalStylesHelper';
import { getColumnStyles } from '../../../compositions/Column/ColumnHelper';

const isCmsEdit = isEditContext(Astro.url);

import { OPTIMIZELY_DATA_PLATFORM_PRIVATE_KEY } from 'astro:env/server';
const odpPrivateKey = OPTIMIZELY_DATA_PLATFORM_PRIVATE_KEY;
const odpTrackFormImpression = !!odpPrivateKey;


export interface Props {
    grid: any;
    contentPayload: ContentPayload;
}

const { grid, contentPayload } = Astro.props as Props;
const nodeType = grid.nodeType;

nodeType && (contentPayload.key = grid.key);

const optiResponse =
    !nodeType &&
    (await getOptimizelySdk(contentPayload).formById({
        key: contentPayload.key,
        //@ts-ignore
        loc: contentPayload.loc as Locales,
        ver: contentPayload.ver,
    }));

const formId = contentPayload.key || grid.key || 'opti-form';

const formItem = optiResponse?.['_Component']?.item;
const formComposition = formItem && 'composition' in formItem ? formItem.composition : formItem;

const formGrid = formComposition ?? grid;
const formNodes = formComposition?.nodes ?? grid.nodes;

let nodeStyles: string[] = [];
let globalStyles: string[] = [];

if (nodeType === 'row') {
	nodeStyles = getRowStyles(formGrid);
} else if (nodeType === 'column') {
	nodeStyles = getColumnStyles(formGrid);
}

if (nodeType === 'row' || nodeType === 'column') {
	globalStyles = getGlobalStyles(formGrid);
}

const styles = [...nodeStyles, ...globalStyles];

const getFormProperty = (propName: string): any => {
	return formGrid?.component?.[propName] ?? formGrid?.[propName];
};

const formTitle: string = getFormProperty('Title') ?? formItem?.Title ?? '';
const formDescription: string | null = getFormProperty('Description') ?? formItem?.Description ?? null;
const formSubmitConfirmationMsg: string | null = getFormProperty('SubmitConfirmationMessage') ?? formItem?.SubmitConfirmationMessage ?? null;
const formResetConfirmationMsg: string = getFormProperty('ResetConfirmationMessage') ?? formItem?.ResetConfirmationMessage ?? 'Are you sure you want to reset the form?';
const formSubmitUrl: string | null = getFormProperty('SubmitUrl')?.default ?? formItem?.SubmitUrl?.default ?? null;
const showSummaryMessage: boolean = getFormProperty('ShowSummaryMessageAfterSubmission') ?? formItem?.ShowSummaryMessageAfterSubmission ?? false;
const formDependencyRules = getFormProperty('DependencyRules') ?? formItem?.DependencyRules ?? null;
const formDependencyRulesJson: string | null = formDependencyRules?.length ? JSON.stringify(formDependencyRules) : null;

const componentClass = 'component-form';
---

{
    (nodeType === 'section' || !nodeType) && (
        <>
            <div class={`vb:section flex flex-col ${componentClass}`} data-epi-block-id={formGrid.key}>
                <form
                    id={formId}
                    class="mx-auto mb-6 w-full rounded-2xl bg-base-100 px-8 py-8 shadow-lg
                           border border-base-200 transition-shadow duration-300 hover:shadow-xl"
                    data-form-rules={formDependencyRulesJson || undefined}
                >
                    {formSubmitUrl && (
                        <input type="hidden" name="formSubmitUrl" value={formSubmitUrl} />
                    )}
                    <input type="hidden" name="formTitle" value={formTitle} />
                    {formTitle && (
                        <h2 class="mb-2 text-2xl font-bold text-base-content">{formTitle}</h2>
                    )}
                    {formDescription && <p class="mb-6 text-base-content/70">{formDescription}</p>}
                    {formNodes?.map((step: any) => (
                        <Astro.self contentPayload={contentPayload} grid={step} />
                    ))}
                </form>
            </div>

            <dialog id={`${formId}-reset-modal`} class="modal modal-middle">
                <div class="modal-box rounded-2xl shadow-2xl bg-base-100 border border-base-200">
                    <h3 class="font-bold text-xl text-base-content">Confirm Form Reset</h3>
                    <p class="py-4 text-base-content/70">{formResetConfirmationMsg}</p>
                    <div class="modal-action justify-center gap-4 pt-2">
                        <button
                            class="btn btn-primary px-6 rounded-xl shadow-md transition-all duration-200
                                   hover:shadow-lg hover:scale-[1.02]"
                            id={`${formId}-reset-confirm-button`}
                        >Confirm</button>
                        <form method="dialog">
                            <button class="btn btn-ghost px-6 rounded-xl border border-base-300
                                          transition-all duration-200 hover:bg-base-200">Cancel</button>
                        </form>
                    </div>
                </div>
                <form method="dialog" class="modal-backdrop bg-base-content/20 backdrop-blur-sm">
                    <button>close</button>
                </form>
            </dialog>
        </>

        <div data-form-id={formId} 
             data-submit-message={formSubmitConfirmationMsg}
             data-reset-message={formResetConfirmationMsg}
        ></div>
        <script>
            import { actions } from "astro:actions";
            import { isInputError } from "astro:actions";

            const element = document.querySelector('[data-form-id]') as HTMLElement;
            const formId = element?.dataset.formId || 'opti-form';
            const submitMessage = element?.dataset.submitMessage || "Form submitted, thank you.";
            const resetMessage = element?.dataset.resetMessage || "Are you sure you want to reset the form?";

            function clearPreviousMessage(id: string) {
                const messageElement = document.getElementById(id);
                if (messageElement) {
                    messageElement.remove();
                }
            }

            function addMessageElement(
                message: string,
                type: "error" | "success",
                element: HTMLElement
            ) {
                const div = document.createElement("div");
                div.id = "message";
                div.className = type === "success"
                    ? "mt-4 p-4 rounded-xl bg-success/10 text-success-content font-medium border border-success/20"
                    : "mt-4 p-4 rounded-xl bg-error/10 text-error-content font-medium border border-error/20";
                div.innerText = message;
                element.appendChild(div);
            }

            function clearInput(formElement: HTMLFormElement) {
                formElement.reset();
            }

            function renderMessage(error: any, data: any, form: HTMLElement) {
                if (error && isInputError(error)) {
                    const message = error.fields.email && error.fields.email[0];
                    addMessageElement(message || "", "error", form);
                } else {
                    if (data?.formSubmitErrors) {
                        const message = data?.formSubmitErrors.message;
                        addMessageElement(message, "error", form);
                    } else {
                        const message = submitMessage ?? "Form submitted successfully.";
                        clearInput(form as HTMLFormElement);
                        addMessageElement(message, "success", form);
                    }
                }
            }

            const form = document.getElementById(formId) as HTMLFormElement;

            async function handleFormSubmit(e: Event) {
                e.preventDefault();

                const formData = new FormData(form);
                const { data, error } = await actions.submitForm(formData);
                clearPreviousMessage("message");
                renderMessage(error, data, form);
            }

            form.addEventListener("submit", handleFormSubmit);

            // Custom validation messages from CMS data attributes
            form.querySelectorAll('input, textarea, select').forEach(function(el) {
                const msgRequired = (el as HTMLElement).dataset.msgRequired;
                const msgType = (el as HTMLElement).dataset.msgType;
                const msgPattern = (el as HTMLElement).dataset.msgPattern;
                if (msgRequired || msgType || msgPattern) {
                    el.addEventListener('invalid', function() {
                        const v = (el as HTMLInputElement).validity;
                        if (v.valueMissing && msgRequired) {
                            (el as HTMLInputElement).setCustomValidity(msgRequired);
                        } else if (v.typeMismatch && msgType) {
                            (el as HTMLInputElement).setCustomValidity(msgType);
                        } else if (v.patternMismatch && msgPattern) {
                            (el as HTMLInputElement).setCustomValidity(msgPattern);
                        }
                    });
                    el.addEventListener('input', function() {
                        (el as HTMLInputElement).setCustomValidity('');
                    });
                    el.addEventListener('change', function() {
                        (el as HTMLInputElement).setCustomValidity('');
                    });
                }
            });

            // Reset button confirmation logic
            const resetButton = form.querySelector('.form-reset-button');
            const resetModal = document.getElementById(`${formId}-reset-modal`) as HTMLDialogElement;
            const confirmResetButton = document.getElementById(`${formId}-reset-confirm-button`);

            if (resetButton && resetModal && confirmResetButton) {
                // Open the modal when the form's reset button is clicked
                resetButton.addEventListener('click', (e) => {
                    e.preventDefault();
                    resetModal.showModal();
                });

                // Handle the actual reset on confirm
                confirmResetButton.addEventListener('click', (e) => {
                    e.preventDefault();
                    clearInput(form);
                    clearPreviousMessage("message");
                    resetModal.close();
                    evaluateAllRules();
                });
            }

            // Form rules engine — dependent field visibility
            const rulesJson = form.dataset.formRules;
            let rules: Array<{
                TargetElement: string;
                SatisfiedAction: string;
                ConditionCombination: string;
                Conditions: Array<{
                    DependsOnField: string;
                    ComparisonOperator: string;
                    ComparisonValue: string;
                }>;
            }> = [];
            if (rulesJson) {
                try {
                    rules = JSON.parse(rulesJson);
                } catch (e) {
                    console.warn('OptiForm: failed to parse form rules JSON', e);
                }
            }

            // Safe escape for use inside CSS attribute value selectors (quoted strings).
            // Prefer the standard CSS.escape API when available, with a minimal fallback.
            function escapeAttr(str: string): string {
                if (typeof CSS !== 'undefined' && typeof CSS.escape === 'function') {
                    return CSS.escape(str);
                }
                return str.replace(/\\/g, '\\\\').replace(/"/g, '\\"');
            }
            function findFieldEl(fieldId: string): Element | null {
                return form.querySelector(`[data-field-key="${escapeAttr(fieldId)}"]`)
                    ?? form.querySelector(`[data-field-name="${escapeAttr(fieldId)}"]`);
            }

            // Collect current values from all visible inputs within a field wrapper.
            function getFieldValues(fieldId: string): string[] {
                const fieldEl = findFieldEl(fieldId);
                if (!fieldEl) return [];
                const values: string[] = [];
                fieldEl.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
                    'input:not([type="hidden"]), textarea, select'
                ).forEach((input) => {
                    if ((input as HTMLInputElement).type === 'checkbox' || (input as HTMLInputElement).type === 'radio') {
                        if ((input as HTMLInputElement).checked) values.push(input.value);
                    } else if (input.tagName === 'SELECT' && (input as HTMLSelectElement).multiple) {
                        Array.from((input as HTMLSelectElement).selectedOptions).forEach((opt) => values.push(opt.value));
                    } else {
                        if (input.value !== '') values.push(input.value);
                    }
                });
                return values;
            }

            let formA11yLiveRegion: HTMLElement | null = null;

            function getFormA11yLiveRegion(): HTMLElement {
                if (formA11yLiveRegion && document.body.contains(formA11yLiveRegion)) {
                    return formA11yLiveRegion;
                }

                const region = document.createElement('div');
                region.setAttribute('aria-live', 'polite');
                region.setAttribute('role', 'status');
                // Visually hidden but available to screen readers
                region.style.position = 'absolute';
                region.style.width = '1px';
                region.style.height = '1px';
                region.style.margin = '-1px';
                region.style.padding = '0';
                region.style.border = '0';
                region.style.clip = 'rect(0 0 0 0)';
                region.style.overflow = 'hidden';

                document.body.appendChild(region);
                formA11yLiveRegion = region;
                return region;
            }

            function applyVisibility(targetEl: Element, visible: boolean) {
                const target = targetEl as HTMLElement;
                target.style.display = visible ? '' : 'none';
                target.setAttribute('aria-hidden', visible ? 'false' : 'true');

                target.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(
                    'input, textarea, select'
                ).forEach((input) => {
                    input.disabled = !visible;
                    // When hiding a field, clear any existing validation state and error flags
                    if (!visible) {
                        if ('setCustomValidity' in input) {
                            input.setCustomValidity('');
                        }
                        (input as HTMLElement).removeAttribute('aria-invalid');
                    }
                });

                try {
                    const liveRegion = getFormA11yLiveRegion();
                    const labelEl = target.querySelector('label');
                    const labelText = (labelEl && (labelEl as HTMLLabelElement).innerText)
                        ? (labelEl as HTMLLabelElement).innerText.trim()
                        : '';
                    const messageBase = labelText
                        ? `Field "${labelText}"`
                        : 'A field';
                    liveRegion.textContent = `${messageBase} is now ${visible ? 'available' : 'unavailable'}.`;
                } catch {
                    // Fail silently if DOM is not available (e.g., during SSR)
                }
            }

            function evaluateCondition(
                condition: { ComparisonOperator: string; ComparisonValue: string },
                fieldValues: string[]
            ): boolean {
                const op = condition.ComparisonOperator;
                const compareValue = condition.ComparisonValue ?? '';
                if (!op || op === 'NotApplicable') return true;
                if (fieldValues.length === 0) return op === 'NotEquals';
                return fieldValues.some((val) => {
                    switch (op) {
                        case 'Equals': return val === compareValue;
                        case 'NotEquals': return val !== compareValue;
                        case 'Contains': return val.includes(compareValue);
                        case 'DoesNotContain': return !val.includes(compareValue);
                        case 'StartsWith': return val.startsWith(compareValue);
                        case 'EndsWith': return val.endsWith(compareValue);
                        case 'MatchRegularExpression': {
                            try { return new RegExp(compareValue).test(val); } catch { return false; }
                        }
                        default: return false;
                    }
                });
            }

            function evaluateRule(rule: typeof rules[number]) {
                const { TargetElement, SatisfiedAction, ConditionCombination, Conditions } = rule;
                if (!Conditions?.length) return;
                const results = Conditions.map((cond) =>
                    evaluateCondition(cond, getFieldValues(cond.DependsOnField))
                );
                const conditionsMet = ConditionCombination === 'Any'
                    ? results.some(Boolean)
                    : results.every(Boolean);
                const shouldBeVisible = SatisfiedAction === 'Show' ? conditionsMet : !conditionsMet;
                const targetEl = findFieldEl(TargetElement);
                if (targetEl) {
                    applyVisibility(targetEl, shouldBeVisible);
                } else {
                    console.warn('[Form Rules] Target element not found for TargetElement:', TargetElement);
                }
            }

            function evaluateAllRules() {
                rules.forEach(evaluateRule);
            }

            if (rules.length) {
                // Build source-field → rules map and attach change/input listeners
                const fieldToRules = new Map<string, typeof rules>();
                rules.forEach((rule) => {
                    rule.Conditions?.forEach((cond) => {
                        const fn = cond.DependsOnField;
                        if (!fn) return;
                        if (!fieldToRules.has(fn)) fieldToRules.set(fn, []);
                        fieldToRules.get(fn)!.push(rule);
                    });
                });

                fieldToRules.forEach((affectedRules, fieldId) => {
                    const fieldEl = findFieldEl(fieldId);
                    if (!fieldEl) {
                        console.warn('[Form Rules] Source field not found for DependsOnField:', fieldId);
                        return;
                    }
                    fieldEl.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
                        'input:not([type="hidden"]), textarea, select'
                    ).forEach((input) => {
                        const handler = () => affectedRules.forEach(evaluateRule);
                        input.addEventListener('change', handler);
                        if (input.tagName === 'INPUT' || input.tagName === 'TEXTAREA') {
                            input.addEventListener('input', handler);
                        }
                    });
                });

                // Apply initial visibility on page load
                evaluateAllRules();
            }
        </script>

        <script is:inline define:vars={{ odpTrackFormImpression, formName: formTitle }}>
            function trackFormImpression() {
                if (odpTrackFormImpression && formName) {
                    if (typeof zaius !== 'undefined') {
                        zaius.event('web_form', {
                            action: 'impression',
                            form_name: formName,
                            campaign: "Form Impression: " + formName
                        });
                    } else {
                        console.warn("ODP script not available for form impression tracking.");
                    }
                }
            }

            // Run on initial page load
            trackFormImpression();

            // Run on subsequent client-side navigations for Astro View Transitions
            document.addEventListener('astro:page-load', trackFormImpression);
        </script>

    )
}

{
    nodeType === 'step' && (
        <div class="vb:step flex flex-col" data-epi-block-id={formGrid.key}>
            {formGrid.nodes?.map((row: any) => (
                <Astro.self contentPayload={contentPayload} grid={row} />
            ))}
        </div>
    )
}

{
    nodeType === 'row' && (
        <div
            class="vb:row flex flex-row flex-wrap justify-start gap-6"
            class:list={styles}
            data-epi-block-id={formGrid.key}
        >
            {formGrid.nodes?.map((column: any) => (
                <Astro.self contentPayload={contentPayload} grid={column} />
            ))}
        </div>
    )
}

{
    nodeType === 'column' && (
        <div
            class="vb:col flex flex-1 flex-col flex-nowrap justify-start gap-5"
            class:list={styles}
            data-epi-block-id={formGrid.key}
        >
            {formGrid.nodes?.map((item: any) => (
                <FormComponents contentPayload={contentPayload} data={item} />
            ))}
        </div>
    )
}

<style is:inline>
    /* Modern validation styling */
    .form-control input:user-invalid,
    .form-control textarea:user-invalid,
    .form-control select:user-invalid {
        border-color: var(--color-error);
        animation: shake 0.3s ease-in-out;
    }

    .form-control input:user-valid,
    .form-control textarea:user-valid,
    .form-control select:user-valid {
        border-color: oklch(var(--su));
    }

    /* Subtle shake animation for errors */
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-4px); }
        75% { transform: translateX(4px); }
    }

</style>
