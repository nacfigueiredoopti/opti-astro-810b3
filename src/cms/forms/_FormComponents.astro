---
import type { ContentPayload } from '../../graphql/shared/ContentPayload';

import Components from '../components/_Components.astro';
import OptiFormsTextboxElement from '../forms/OptiFormsTextboxElementComponent/OptiFormsTextboxElement.astro';
import OptiFormsNumberElement from '../forms/OptiFormsNumberElementComponent/OptiFormsNumberElement.astro';
import OptiFormsRangeElement from '../forms/OptiFormsRangeElementComponent/OptiFormsRangeElement.astro';
import OptiFormsSelectionElement from '../forms/OptiFormsSelectionElementComponent/OptiFormsSelectionElement.astro';
import OptiFormsTextareaElement from '../forms/OptiFormsTextareaElementComponent/OptiFormsTextareaElement.astro';
import OptiFormsUrlElement from '../forms/OptiFormsUrlElementComponent/OptiFormsUrlElement.astro';
import OptiFormsChoiceElement from '../forms/OptiFormsChoiceElementComponent/OptiFormsChoiceElement.astro';
import OptiFormsSubmitElement from '../forms/OptiFormsSubmitElementComponent/OptiFormsSubmitElement.astro';
import OptiFormsResetElement from '../forms/OptiFormsResetElementComponent/OptiFormsResetElement.astro';
import OptiFormsDateTimeElement from '../forms/OptiFormsDateTimeElementComponent/OptiFormsDateTimeElement.astro';
import OptiFormsHiddenFieldElement from '../forms/OptiFormsHiddenFieldElementComponent/OptiFormsHiddenFieldElement.astro';
import OptiFormsPrebuiltListElement from '../forms/OptiFormsPrebuiltListElementComponent/OptiFormsPrebuiltListElement.astro';

interface Props {
    contentPayload: ContentPayload;
    data: any;
}

const { contentPayload, data } = Astro.props as Props;
const { component, displaySettings, displayTemplateKey } = data;
const componentType = component._metadata.types[0];
---

{
    componentType === 'OptiFormsTextboxElement' && (
        <OptiFormsTextboxElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
            nodeKey={data.key}
        />
    )
}

{
    componentType === 'OptiFormsTextareaElement' && (
        <OptiFormsTextareaElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
            nodeKey={data.key}
        />
    )
}

{
    componentType === 'OptiFormsNumberElement' && (
        <OptiFormsNumberElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
            nodeKey={data.key}
        />
    )
}
{
    componentType === 'OptiFormsUrlElement' && (
        <OptiFormsUrlElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
            nodeKey={data.key}
        />
    )
}

{
    componentType === 'OptiFormsSelectionElement' && (
        <OptiFormsSelectionElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
            nodeKey={data.key}
        />
    )
}

{
    componentType === 'OptiFormsRangeElement' && (
        <OptiFormsRangeElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
            nodeKey={data.key}
        />
    )
}

{
    componentType === 'OptiFormsChoiceElement' && (
        <OptiFormsChoiceElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
            nodeKey={data.key}
        />
    )
}

{
    componentType === 'OptiFormsDateTimeElement' && (
        <OptiFormsDateTimeElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
            nodeKey={data.key}
        />
    )
}

{
    componentType === 'OptiFormsHiddenFieldElement' && (
        <OptiFormsHiddenFieldElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
        />
    )
}

{
    componentType === 'OptiFormsPrebuiltListElement' && (
        <OptiFormsPrebuiltListElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
            nodeKey={data.key}
        />
    )
}

{
    componentType === 'OptiFormsSubmitElement' && (
        <OptiFormsSubmitElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
        />
    )
}
{
    componentType === 'OptiFormsResetElement' && (
        <OptiFormsResetElement
            contentPayload={contentPayload}
            data={component}
            displaySettings={displaySettings}
        />
    )
}

{
    // Fallback: render any non-form component (e.g. Text, Paragraph) using the generic renderer.
    // Convention: all Optimizely form element types must use the "OptiForms" prefix.
    !componentType.startsWith('OptiForms') && (
        <Components contentPayload={contentPayload} data={data} />
    )
}
