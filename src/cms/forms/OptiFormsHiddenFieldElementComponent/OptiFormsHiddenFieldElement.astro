---
import type { DisplaySettingsFragment, OptiFormsHiddenFieldElement } from '../../../../__generated/sdk';
import type { ContentPayload } from '../../../graphql/shared/ContentPayload';
import { isEditContext, isPreviewContext } from '../../shared/utils';

export interface Props {
    data: OptiFormsHiddenFieldElement;
    contentPayload: ContentPayload;
    displaySettings: DisplaySettingsFragment[];
}

const { data, contentPayload } = Astro.props as Props;
const { HiddenFieldType, Label, PredefinedValue } = data;

const fieldName = Label?.replace(/\s+/g, '_') || HiddenFieldType || 'hidden';

const resolvedValue = (() => {
    switch (HiddenFieldType) {
        case 'currentpage':   return Astro.url.href;
        case 'locale':        return contentPayload.loc ?? '';
        case 'referer':       return Astro.request.headers.get('referer') ?? '';
        case 'useragent':     return Astro.request.headers.get('user-agent') ?? '';
        case 'utm_campaign':  return Astro.url.searchParams.get('utm_campaign') ?? '';
        case 'utm_content':   return Astro.url.searchParams.get('utm_content') ?? '';
        case 'utm_medium':    return Astro.url.searchParams.get('utm_medium') ?? '';
        case 'utm_source':    return Astro.url.searchParams.get('utm_source') ?? '';
        case 'utm_term':       return Astro.url.searchParams.get('utm_term') ?? '';
        case 'predefinedvalue': return PredefinedValue || null;
        default:               return '';
    }
})();

const isCmsContext = isEditContext(Astro.url) || isPreviewContext(Astro.url);
---

{resolvedValue !== null && <input type="hidden" name={fieldName} value={resolvedValue} />}

{isCmsContext && (
    <div class="flex items-center gap-2 rounded border border-dashed border-base-300 bg-base-200/50 px-3 py-2 text-sm text-base-content/60">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 4.411m0 0L21 21" />
        </svg>
        <span>Hidden field — <strong>{HiddenFieldType ?? 'unconfigured'}</strong>{Label && <> → <code>{fieldName}</code></>}</span>
    </div>
)}
