---
import type { ContentPayload } from '../../../graphql/shared/ContentPayload';
import { isEditContext } from '../../shared/utils.ts';

const isCmsEdit = isEditContext(Astro.url);

export interface Props {
    key: string;
    data: any;
    displaySettings: any[];
    displayTemplateKey: string;
    contentPayload: ContentPayload;
}

const { key, data } = Astro.props as Props;

const title = data?.Title || data?._metadata?.displayName || '';
const description = data?.Description || '';
const link = data?.Link?.url?.hierarchical || data?.Link?.url?.default || '#';

// Rabobank card descriptions and which get the navy-blue accent
const productInfo: Record<string, { desc: string; blue: boolean }> = {
    'Betalen':     { desc: 'Kies de betaalrekening die bij je past.', blue: true },
    'Sparen':      { desc: 'Wat je spaardoel ook is, wij helpen je verder.', blue: false },
    'Hypotheken':  { desc: 'Verhuizen of verbouwen? Bereken snel wat je kunt lenen.', blue: true },
    'Hypotheek':   { desc: 'Verhuizen of verbouwen? Bereken snel wat je kunt lenen.', blue: true },
    'Verzekeren':  { desc: 'Goed verzekerd zijn, helpt je om financieel gezond te blijven. Tot 12% pakketkorting op schadeverzekeringen.', blue: false },
    'Beleggen':    { desc: 'Bouw met ons vermogen op, voor nu en later.', blue: true },
    'Pensioen':    { desc: 'Straks net zo lekker leven als nu? Wij denken met je mee.', blue: false },
    'Lenen':       { desc: 'Verbouwing, nieuwe auto of verduurzamen? Ontdek een persoonlijke lening bij je past.', blue: false },
};

const info = productInfo[title] || { desc: description, blue: false };
const cardDesc = description || info.desc;
const isBlue = info.blue;
const isWide = title === 'Verzekeren';
---

<a
    href={link !== '#' ? link : `/${title.toLowerCase()}/`}
    class:list={[
        'rounded-xl p-6 relative group transition-all duration-300 flex border',
        isWide ? 'col-span-full flex-col md:flex-row md:items-center md:justify-between min-h-[100px]' : 'flex-col justify-between min-h-[150px]',
    ]}
    style={isBlue
        ? 'background-color: #003082; border-color: rgba(0,48,130,0.5); color: #FFFFFF;'
        : 'background-color: #1B2234; border-color: #253044; color: #E6EAF0;'}
    data-epi-block-id={isCmsEdit && key || undefined}
>
    <div>
        <h3 class="text-xl font-bold italic mb-2" style={isBlue ? 'color: #FF6600;' : 'color: #E6EAF0;'}>{title}</h3>
        <p class="text-sm leading-relaxed" style="opacity: 0.7;">{cardDesc}</p>
    </div>
    <div class:list={[isWide ? 'mt-4 md:mt-0 md:ml-8 flex-shrink-0' : 'self-end mt-4']}>
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" style="opacity: 0.5;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
    </div>
</a>
