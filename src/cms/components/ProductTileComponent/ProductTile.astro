---
import type { ContentPayload } from '../../../graphql/shared/ContentPayload';
import { isEditContext } from '../../shared/utils.ts';

const isCmsEdit = isEditContext(Astro.url);

export interface Props {
    key: string;
    data: any;
    displaySettings: any[];
    displayTemplateKey: string;
    contentPayload: ContentPayload;
}

const { key, data, displaySettings, contentPayload } = Astro.props as Props;

const title = data?.Title || data?._metadata?.displayName || '';
const description = data?.Description || '';
const link = data?.Link?.url?.hierarchical || data?.Link?.url?.default || '#';

// Map product names to descriptions and accent styles
const productInfo: Record<string, { desc: string; accent: boolean }> = {
    'Betalen':     { desc: 'Kies de betaalrekening die bij je past.', accent: true },
    'Sparen':      { desc: 'Wat je spaardoel ook is, wij helpen je verder.', accent: false },
    'Hypotheken':  { desc: 'Verhuizen of verbouwen? Bereken snel wat je kunt lenen.', accent: true },
    'Hypotheek':   { desc: 'Verhuizen of verbouwen? Bereken snel wat je kunt lenen.', accent: true },
    'Verzekeren':  { desc: 'Goed verzekerd zijn, helpt je om financieel gezond te blijven. Tot 12% pakketkorting op schadeverzekeringen.', accent: false },
    'Beleggen':    { desc: 'Bouw met ons vermogen op, voor nu en later.', accent: true },
    'Pensioen':    { desc: 'Straks net zo lekker leven als nu? Wij denken met je mee.', accent: false },
    'Lenen':       { desc: 'Verbouwing, nieuwe auto of verduurzamen? Ontdek een persoonlijke lening.', accent: false },
};

const info = productInfo[title] || { desc: description, accent: false };
const cardDesc = description || info.desc;
const isAccent = info.accent; // Accent cards have blue-navy highlight like rabobank.nl
const isWide = title === 'Verzekeren';

const componentClass = 'component-producttile';
---

<a
    href={link !== '#' ? link : `/${title.toLowerCase()}/`}
    class:list={[
        'rounded-xl p-6 relative group transition-all duration-300 flex border',
        isAccent ? 'bg-secondary text-secondary-content border-secondary/30 hover:border-secondary/60' : 'bg-base-200 text-base-content border-base-300/50 hover:border-base-300',
        isWide ? 'col-span-full flex-col md:flex-row md:items-center md:justify-between min-h-[100px]' : 'flex-col justify-between min-h-[150px]',
        componentClass
    ]}
    data-epi-block-id={isCmsEdit && key || undefined}
>
    <div>
        <h3 class:list={['text-xl font-bold italic mb-2', isAccent ? 'text-primary' : 'text-base-content']}>{title}</h3>
        <p class="text-sm opacity-70 leading-relaxed">{cardDesc}</p>
    </div>
    <div class:list={[isWide ? 'mt-4 md:mt-0 md:ml-8 flex-shrink-0' : 'self-end mt-4']}>
        <svg class="w-5 h-5 opacity-50 group-hover:opacity-80 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
    </div>
</a>
