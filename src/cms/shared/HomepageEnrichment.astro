---
/**
 * Homepage enrichment sections (below CMS content).
 * Styled to match rabobank.nl dark navy design.
 */
---

<!-- Wees alert -->
<section class="mx-auto max-w-screen-xl px-6 py-12 md:py-16" data-aos="fade-up">
    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <div class="w-full md:w-5/12 flex-shrink-0">
            <img src="https://images.unsplash.com/photo-1581579438747-104c53d7fbc4?w=600&h=450&fit=crop&crop=faces" alt="Persoon leest op de bank" class="rounded-lg w-full h-auto object-cover" loading="lazy" width="600" height="450" />
        </div>
        <div class="w-full md:w-7/12">
            <h2 class="text-3xl md:text-4xl font-bold italic mb-4" style="color: #E6EAF0;">Wees alert</h2>
            <p class="text-base leading-relaxed mb-6" style="color: rgba(230,234,240,0.6);">
                Steeds vaker raken organisaties betrokken bij datalekken. En zodra jouw
                gegevens op straat liggen, staan criminelen klaar om toe te slaan: via slimme
                phishingtrucs, een telefoontje van een 'bankmedewerker' die net echt klinkt of
                een ogenschijnlijk nette betalingsherinnering. Door bewust te blijven, houd je
                zelf de controle over je eigen veiligheid.
            </p>
            <a href="/en/veilig-online-bankieren/" class="inline-flex items-center gap-2 font-semibold hover:underline transition" style="color: #FF6600;">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M9 12l2 2 4-4"></path></svg>
                Herken en voorkom fraude
            </a>
        </div>
    </div>
</section>

<!-- Rabo App -->
<section class="mx-auto max-w-screen-xl px-6 py-8 md:py-12" data-aos="fade-up">
    <div class="rounded-2xl overflow-hidden" style="background-color: #151C2C; border: 1px solid #253044;">
        <div class="flex flex-col md:flex-row items-stretch">
            <div class="w-full md:w-1/2 p-8 md:p-12 lg:p-16 flex flex-col justify-center">
                <h2 class="text-3xl md:text-4xl font-bold italic mb-4" style="color: #E6EAF0;">Bankzaken regel je met de Rabo App</h2>
                <p class="text-base leading-relaxed mb-6" style="color: rgba(230,234,240,0.6);">Spontaan uit eten vanavond? Check direct in de Rabo App hoe je ervoor staat.</p>
                <ul class="space-y-3 mb-8">
                    <li class="flex items-center gap-3" style="color: #E6EAF0;">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" style="color: #22C55E;" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span>Altijd en overal toegang tot je bankzaken</span>
                    </li>
                    <li class="flex items-center gap-3" style="color: #E6EAF0;">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" style="color: #22C55E;" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span>Handige tips en features</span>
                    </li>
                    <li class="flex items-center gap-3" style="color: #E6EAF0;">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" style="color: #22C55E;" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span>Uitgebreide online omgeving</span>
                    </li>
                </ul>
                <div><a href="/betalen/rabo-app/" class="btn text-white border-0 rounded-lg px-6" style="background-color: #FF6600;">Lees meer</a></div>
            </div>
            <div class="w-full md:w-1/2 flex justify-center items-end">
                <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=500&h=600&fit=crop&crop=center" alt="Rabo App op smartphone" class="w-full h-full object-cover" loading="lazy" width="500" height="600"/>
            </div>
        </div>
    </div>
</section>

<!-- Promo Card -->
<section class="mx-auto max-w-screen-xl px-6 py-8 md:py-12" data-aos="fade-up">
    <div class="relative rounded-2xl overflow-hidden">
        <img src="https://images.unsplash.com/photo-1517457373958-b7bdd4587205?w=1200&h=500&fit=crop&crop=top" alt="Vrienden op een dakterras" class="w-full h-64 md:h-96 object-cover" loading="lazy" width="1200" height="500"/>
        <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(13,17,23,0.95), rgba(13,17,23,0.4), transparent);"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
            <h2 class="text-2xl md:text-3xl font-bold italic mb-3" style="color: #FFFFFF;">Open een betaalrekening en ontdek alle voordelen</h2>
            <p class="text-sm md:text-base max-w-xl mb-6" style="color: rgba(255,255,255,0.7);">Naar de bios, een etentje met vrienden of sparen voor later? Jij bepaalt waar je je geld aan uitgeeft.</p>
            <div class="flex flex-wrap gap-3">
                <a href="/betalen/betaalrekening/" class="btn text-white border-0 rounded-lg px-6" style="background-color: #FF6600;">Bekijk betaalrekeningen</a>
                <a href="/betalen/creditcard/" class="btn bg-transparent border rounded-lg px-6" style="color: #FFFFFF; border-color: rgba(255,255,255,0.4);">Bekijk creditcards</a>
            </div>
        </div>
    </div>
</section>

<!-- Financieel inzicht -->
<section class="mx-auto max-w-screen-xl px-6 py-8 md:py-12" data-aos="fade-up">
    <div class="rounded-2xl overflow-hidden" style="background-color: #151C2C; border: 1px solid #253044;">
        <div class="flex flex-col md:flex-row items-stretch">
            <div class="w-full md:w-1/2 p-8 md:p-12 lg:p-16 flex flex-col justify-center">
                <h2 class="text-2xl md:text-3xl font-bold italic mb-4" style="color: #E6EAF0;">Financieel inzicht: tips en artikelen</h2>
                <p class="text-base leading-relaxed mb-6" style="color: rgba(230,234,240,0.6);">Van je eerste huis kopen tot duurzaam beleggen. Ontdek verhalen, tips en inzichten die je helpen om slimmer met je geld om te gaan.</p>
                <div><a href="/en/eerste-huis-kopen-tips/" class="btn text-white border-0 rounded-lg px-6" style="background-color: #FF6600;">Lees de artikelen</a></div>
            </div>
            <div class="w-full md:w-1/2">
                <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&h=500&fit=crop&crop=center" alt="Mensen in gesprek" class="w-full h-full object-cover min-h-64" loading="lazy" width="600" height="500"/>
            </div>
        </div>
    </div>
</section>

<!-- Heb je vragen? -->
<section class="mx-auto max-w-screen-xl px-6 py-12 md:py-16" data-aos="fade-up">
    <h2 class="text-3xl md:text-4xl font-bold italic mb-2" style="color: #E6EAF0;">Heb je vragen?</h2>
    <p class="mb-8" style="color: rgba(230,234,240,0.5);">Neem contact met ons op waar en wanneer je maar wilt.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Chat -->
        <div class="rounded-2xl overflow-hidden flex flex-col md:flex-row" style="background-color: #151C2C; border: 1px solid #253044;">
            <div class="p-6 md:p-8 flex flex-col justify-end flex-1">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background-color: rgba(255,102,0,0.15);">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #FF6600;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                </div>
                <h3 class="text-lg font-bold italic mb-1" style="color: #E6EAF0;">Stel je vraag via chat</h3>
                <p class="text-sm mb-4" style="color: rgba(230,234,240,0.5);">Direct antwoord van Robin, onze virtuele chat assistent.</p>
                <div><a href="/en/service-contact/" class="btn btn-sm rounded-lg" style="background-color: #253044; color: #E6EAF0; border-color: #253044;">Start de chat</a></div>
            </div>
            <div class="w-full md:w-1/2 flex-shrink-0">
                <img src="https://images.unsplash.com/photo-1573497620053-ea5300f94f21?w=400&h=300&fit=crop&crop=faces" alt="Klantenservice" class="w-full h-48 md:h-full object-cover" loading="lazy" width="400" height="300"/>
            </div>
        </div>
        <!-- Phone + Online -->
        <div class="flex flex-col gap-4">
            <a href="/en/service-contact/" class="rounded-2xl p-6 md:p-8 flex-1 transition-colors group" style="background-color: #151C2C; border: 1px solid #253044;">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background-color: #253044;">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: rgba(230,234,240,0.6);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <h3 class="text-base font-bold italic mb-1" style="color: #E6EAF0;">Bel met een van onze medewerkers</h3>
                <p class="text-sm mb-3" style="color: rgba(230,234,240,0.5);">Bereikbaar op werkdagen van 9.00 tot 17.00 uur.</p>
                <span class="btn btn-sm rounded-lg" style="background-color: transparent; color: #E6EAF0; border-color: #253044;">Bel ons</span>
            </a>
            <a href="/en/service-contact/" class="rounded-2xl p-6 md:p-8 flex-1 transition-colors group" style="background-color: #151C2C; border: 1px solid #253044;">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background-color: #253044;">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: rgba(230,234,240,0.6);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>
                <h3 class="text-base font-bold italic mb-1" style="color: #E6EAF0;">Online klantenservice</h3>
                <p class="text-sm mb-3" style="color: rgba(230,234,240,0.5);">Vind het antwoord op onze website.</p>
                <span class="btn btn-sm rounded-lg" style="background-color: transparent; color: #E6EAF0; border-color: #253044;">Service & contact</span>
            </a>
        </div>
    </div>
</section>
