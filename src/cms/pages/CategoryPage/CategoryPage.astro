---
import { Image as AstroImage } from 'astro:assets';
import type { Locales } from 'astro';
import type { CategoryPageFragment } from '../../../../__generated/sdk';
import { getOptimizelySdk } from '../../../graphql/getSdk';
import type { ContentPayload } from '../../../graphql/shared/ContentPayload';
import Layout from '../../../layouts/Layout.astro';
import ContentArea from '../../shared/ContentArea/ContentArea.astro';
import HomepageEnrichment from '../../shared/HomepageEnrichment.astro';

export interface Props {
    contentPayload: ContentPayload;
}
const { contentPayload } = Astro.props as Props;

const optiResponse = await getOptimizelySdk(contentPayload).pageById({
    key: contentPayload.key,
    //@ts-ignore
    loc: contentPayload.loc as Locales,
    ver: contentPayload.ver,
});

const page = optiResponse?._Page?.item as CategoryPageFragment;

const graphType = page?.SeoSettings?.GraphType ?? 'website';
const defaultUrl = page?._metadata?.url?.default || '';
const hierarchicalUrl =
    page?._metadata?.url?.type === 'SIMPLE'
        ? page?._metadata?.url?.hierarchical
        : '';
const extPreviewEnabled = page?.PageAdminSettings?.EnableExternalPreview ?? false;

const heroUrl = (page?.HeroImage as any)?.item?.Url || page?.HeroImage?.url?.default || null;

// Detect if this is the homepage
const pathname = Astro.url.pathname;
const isHomepage = pathname === '/' || pathname === '/en/' || /^\/[a-z]{2}(-[a-z]{2})?\/?$/.test(pathname);

const pageClass = 'page-category';
---

<Layout
    title={page?.SeoSettings?.MetaTitle ??
        page?.Heading ??
        page?._metadata?.displayName ??
        'Category'}
    description={page?.SeoSettings?.MetaDescription ??
        page?.SubHeading ?? ''}
    graphtype={graphType}
    indexing={page?.SeoSettings?.Indexing ?? false}
    contentPayload={contentPayload}
    defaultUrl={defaultUrl}
    hierarchicalUrl={hierarchicalUrl ?? ''}
    extPreviewEnabled={extPreviewEnabled}
>
    <div class={`max-w-screen-6xl mx-auto ${pageClass}`}>
        <!-- Hero -->
        {heroUrl ? (
            <section class="relative flex w-full items-center min-h-[450px] md:min-h-[550px] overflow-hidden">
                <AstroImage
                    src={heroUrl}
                    alt={page?.Heading || ''}
                    class="absolute inset-0 h-full w-full object-cover"
                    inferSize={true}
                />
                <div class="absolute inset-0 bg-gradient-to-r from-base-100/90 via-base-100/50 to-transparent"></div>
                <div class="relative z-10 px-6 md:px-12 lg:px-20 py-16 max-w-screen-xl mx-auto w-full">
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-base-content mb-4">{page?.Heading}</h1>
                    {page?.SubHeading && (
                        <p class="text-lg md:text-xl text-base-content/70 max-w-lg">{page.SubHeading}</p>
                    )}
                </div>
                <!-- Scroll indicator -->
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10">
                    <svg class="w-8 h-8 text-base-content/40 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>
            </section>
        ) : page?.Heading && (
            <section class="mx-auto max-w-screen-xl px-6 pt-12 pb-6">
                <h1 class="text-4xl md:text-5xl font-bold text-base-content mb-3">{page.Heading}</h1>
                {page?.SubHeading && (
                    <p class="text-base-content/50 text-lg max-w-2xl">{page.SubHeading}</p>
                )}
            </section>
        )}

        <!-- Introduction -->
        {page?.Introduction?.html && (
            <section class="mx-auto max-w-screen-xl px-6 py-6">
                <div class="prose prose-invert prose-lg max-w-3xl text-base-content/70" set:html={page.Introduction.html} />
            </section>
        )}

        <!-- Product Cards -->
        {page?.ProductCards && (page.ProductCards as any[]).length > 0 && (
            <section class="mx-auto max-w-screen-xl px-6 pb-12">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {(page.ProductCards as any[]).map((contentAreaItem: any) => (
                        <ContentArea
                            contentPayload={contentPayload}
                            contentAreaItem={contentAreaItem}
                        />
                    ))}
                </div>
            </section>
        )}

        <!-- Main Content Area -->
        {page?.MainContentArea && (page.MainContentArea as any[]).length > 0 && (
            <section class="mx-auto max-w-screen-xl px-6 py-8">
                {(page.MainContentArea as any[]).map((contentAreaItem: any) => (
                    <ContentArea
                        contentPayload={contentPayload}
                        contentAreaItem={contentAreaItem}
                    />
                ))}
            </section>
        )}

        <!-- Homepage enrichment -->
        {isHomepage && <HomepageEnrichment />}
    </div>
</Layout>
