---
import { Image as AstroImage } from 'astro:assets';
import type { Locales } from 'astro';
import { format } from 'date-fns';
import type { NewsArticlePageFragment } from '../../../../__generated/sdk';
import { getOptimizelySdk } from '../../../graphql/getSdk';
import type { ContentPayload } from '../../../graphql/shared/ContentPayload';
import Layout from '../../../layouts/Layout.astro';
import { isEditContext } from '../../shared/utils.ts';

const isCmsEdit = isEditContext(Astro.url);

export interface Props {
    contentPayload: ContentPayload;
}
const { contentPayload } = Astro.props as Props;

const optiResponse = await getOptimizelySdk(contentPayload).pageById({
    key: contentPayload.key,
    //@ts-ignore
    loc: contentPayload.loc as Locales,
    ver: contentPayload.ver,
});
const post = optiResponse?._Page?.item as NewsArticlePageFragment;
const publishedDate = format(
    new Date(post?._metadata?.published ?? Date.now()),
    'dd MMM yyyy'
);

const heroUrl = (post.HeroImage as any)?.item?.Url || post.HeroImage?.url?.default
    || (post.PromoImage as any)?.item?.Url || post.PromoImage?.url?.default || null;
const hasImage = !!heroUrl;
const headerTextColor = hasImage ? 'text-neutral-content' : 'text-base-content';
const headerSubColor = hasImage ? 'text-neutral-content/75' : 'text-base-content/65';
const headerDateColor = hasImage ? 'text-neutral-content/55' : 'text-base-content/50';

const graphType = post?.SeoSettings?.GraphType && post?.SeoSettings?.GraphType !== '-'
    ? post?.SeoSettings?.GraphType : 'article';
const defaultUrl = post?._metadata?.url?.default || '';
const hierarchicalUrl = post?._metadata?.url?.type === 'SIMPLE'
    ? post?._metadata?.url?.hierarchical : '';
const extPreviewEnabled = post?.PageAdminSettings?.EnableExternalPreview ?? false;

const pageClass = 'page-news-article';
---

<Layout
    title={post.SeoSettings?.MetaTitle ?? post?.Heading ?? post?._metadata?.displayName ?? 'News'}
    description={post.SeoSettings?.MetaDescription ?? post?.Summary ?? ''}
    graphtype={graphType}
    indexing={post.SeoSettings?.Indexing ?? false}
    contentPayload={contentPayload}
    defaultUrl={defaultUrl}
    hierarchicalUrl={hierarchicalUrl ?? ''}
    extPreviewEnabled={extPreviewEnabled}
>
    <div class={`max-w-screen-6xl mx-auto ${pageClass}`}>
        <main class="mt-10">
            <!-- Hero header -->
            <div class="relative mx-auto mb-4 w-full max-w-screen-xl md:mb-0 bg-base-200" style="height: 24em;">
                {hasImage && (
                    <div class="absolute bottom-0 start-0 z-10 h-full w-full"
                        style="background-image: linear-gradient(180deg,transparent,rgba(0,0,0,.7));">
                    </div>
                    <AstroImage
                        src={heroUrl}
                        class="absolute top-0 start-0 z-0 h-full w-full object-cover"
                        alt={post.Heading || 'News article image'}
                        inferSize={true}
                    />
                )}
                <div class="absolute bottom-0 start-0 z-20 p-4">
                    {post.Category && (
                        <span class="badge badge-primary mb-3">
                            {post.Icon && <span class="mr-1">{post.Icon}</span>}
                            {post.Category}
                        </span>
                    )}
                    <h1 class={`text-4xl lg:text-6xl leading-tight font-semibold pb-4 ${headerTextColor}`}
                        data-epi-edit={isCmsEdit ? 'Heading' : undefined}>
                        {post?.Heading}
                    </h1>
                    {post?.Summary && (
                        <p class={`text-lg lg:text-xl leading-snug mb-3 ${headerSubColor}`}
                            data-epi-edit={isCmsEdit ? 'Summary' : undefined}>
                            {post.Summary}
                        </p>
                    )}
                    <div class="mt-3 flex items-center gap-4">
                        <p class={`text-xs font-semibold ${headerDateColor}`}>{publishedDate}</p>
                        {post.ReadTime && (
                            <p class={`text-xs ${headerDateColor}`}>{post.ReadTime} leestijd</p>
                        )}
                    </div>
                </div>
            </div>

            <!-- Article body -->
            <article
                class="prose dark:prose-invert md:prose-lg lg:prose-xl mx-auto mt-12 mb-12 max-w-screen-xl px-4 2xl:px-0 prose-img:rounded-[2rem] prose-img:p-4"
                data-epi-edit={isCmsEdit ? 'Body' : undefined}
                set:html={post.Body?.html}
            />
        </main>
    </div>
</Layout>
